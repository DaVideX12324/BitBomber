[ext_resource type="Shader" uid="uid://byuec8inr4t8x" path="res://shaders/bomb.gdshader" id="2_cyuu0"]

[sub_resource type="Shader" id="Shader_unqwv"]
code = "shader_type canvas_item;

// Kolor żółty
uniform vec4 highlight_color : source_color = vec4(1.0, 1.0, 0.0, 1.0); 
// Postęp przekazywany ze skryptu (od 0.0 do 1.0)
uniform float progress : hint_range(0.0, 1.0) = 0.0;
// Maksymalna grubość obwódki w pikselach
uniform float max_outline_width : hint_range(0.0, 20.0) = 10.0; 

void fragment() {
	vec2 uv = UV;
	vec4 tex_color = texture(TEXTURE, uv);
	float a = tex_color.a;

	// Tuż przed wybuchem (> 90% czasu), cała bomba staje się żółta
	if (progress > 0.9) {
		if (a > 0.0) {
			COLOR = highlight_color;
		} else {
			COLOR = vec4(0.0);
		}
	} 
	// Przez resztę czasu wyświetlamy powiększającą się obwódkę
	else {
		float current_width = progress * max_outline_width;
		
		// Jeśli dany piksel jest przezroczysty, sprawdzamy, czy nie nałożyć tu obwódki
		if (a == 0.0 && current_width > 0.0) {
			vec2 size = TEXTURE_PIXEL_SIZE;
			float outline_alpha = 0.0;
			
			// Sprawdzanie pobliskich pikseli w 8 kierunkach
			outline_alpha += texture(TEXTURE, uv + vec2(-current_width, 0.0) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(current_width, 0.0) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(0.0, -current_width) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(0.0, current_width) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(-current_width, -current_width) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(current_width, current_width) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(-current_width, current_width) * size).a;
			outline_alpha += texture(TEXTURE, uv + vec2(current_width, -current_width) * size).a;
			
			// Jeśli dotknęliśmy sprite'a bomby obwódką, malujemy na żółto
			if (outline_alpha > 0.0) {
				COLOR = highlight_color;
			} else {
				COLOR = vec4(0.0); // Zostawiamy przezroczyste
			}
		} else {
			// Zwykły rysunek bomby w jej wnętrzu
			COLOR = tex_color;
		}
	}
}"

