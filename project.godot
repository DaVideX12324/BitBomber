; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in [] on its own line
;   param=value ; . is identifier separator, e.g. section.title

config_version=5

[application]

config/name="BitBomber"
config/description="Edukacyjna gra Bomberman — lokalny multiplayer z quizami"
run/main_scene="res://scenes/menus/main_menu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoloads/game_manager.gd"
RoundManager="*res://autoloads/round_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

